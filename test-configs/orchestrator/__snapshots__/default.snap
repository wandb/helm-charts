            cpu: 32
            memory: 64Gi
          requests:
            cpu: 8
            memory: 16Gi
      serviceAccountName: chartsnap-workspace-engine
      securityContext:
        fsGroup: 0
        fsGroupChangePolicy: OnRootMismatch
        runAsGroup: 0
        runAsNonRoot: true
        runAsUser: 999
        seccompProfile:
          type: RuntimeDefault
      terminationGracePeriodSeconds: 60
      topologySpreadConstraints:
      - labelSelector:
