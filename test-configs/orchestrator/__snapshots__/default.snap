    app.kubernetes.io/managed-by: Helm
roleRef:
  kind: ClusterRole
  apiGroup: rbac.authorization.k8s.io
  name: chartsnap-otel
subjects:
- kind: ServiceAccount
  name: chartsnap-otel
  namespace: default
